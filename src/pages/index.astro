---
import Base from '../layouts/Base.astro';

const WHATSAPP = 'https://api.whatsapp.com/send?phone=5511991079503';
const EMAIL = 'contato@viacsc.com.br';

const planos = [
  {
    nome: 'Contabilidade VIA Básico',
    subtitulo: 'Para você que é MEI ou está começando agora',
    destaque: false,
    itens: [
      'Plataforma VIA atendimento',
      'WhatsApp exclusivo',
      'Acompanhamento do CNPJ',
      'Declaração e impostos inclusos',
    ],
  },
  {
    nome: 'Contabilidade VIA Plus',
    subtitulo: 'Para você que cresceu e precisa de mais funcionalidades',
    destaque: true,
    itens: [
      'Plataforma VIA atendimento',
      'WhatsApp exclusivo',
      'Acompanhamento do CNPJ',
      'Declaração e impostos inclusos',
      'DRE',
      'Balancete e Balanço',
    ],
  },
  {
    nome: 'BPO Via',
    subtitulo: 'Tenha o controle completo da sua rede de negócios',
    destaque: false,
    itens: [
      'Plataforma VIA atendimento',
      'WhatsApp exclusivo',
      'Acompanhamento do CNPJ',
      'Declaração e impostos inclusos',
      'DRE',
      'Balancete e Balanço',
      'Contas a pagar',
      'Contas a receber',
      'Conciliações',
      'Relatórios',
    ],
  },
];

const timeline = [
  { ano: '2007', texto: 'A DryWash enfrenta desafios administrativos que dão origem a toda a história.' },
  { ano: '2010', texto: 'Criação do Centro de Serviços Compartilhados, reduzindo custos e liberando foco para as atividades estratégicas.' },
  { ano: '2012', texto: 'Fundação da VIA Indicadores.' },
  { ano: '2014', texto: 'Incorporação da InfraNet Solutions, com Rodrigo Martins como CEO.' },
  { ano: '2015', texto: 'A VIA expande seus serviços além da DryWash e reposiciona sua marca.' },
  { ano: 'Hoje', texto: 'Soluções automatizadas de back-office para micro e pequenas empresas, com expertise em gestão para franqueadoras e MEIs — centralizando processos e reduzindo custos.' },
];

const semVia = [
  'Cliente paga',
  'Estabelecimento recebe',
  'Criação de planilhas manuais para pagamento',
  'Divisão manual de pagamento',
];

const comVia = [
  'Cliente paga',
  'A VIA faz a divisão automática dos pagamentos',
  'Todos recebem automaticamente em suas contas',
];
---
<Base
  title="Via CSC — Contabilidade Inteligente, BPO Financeiro e Split de Pagamentos"
  description="Soluções para ganhos financeiros, tributários e operacionais. Aproveite a gestão de PDV, financeira e contábil em um único lugar."
>
  <!-- ===== Header ===== -->
  <header class="header">
    <div class="container header__inner">
      <a href="#" class="header__logo" aria-label="Via CSC — página inicial">
        <img src="/logo-via.svg" alt="VIA" width="88" height="30" />
      </a>
      <nav class="header__nav" aria-label="Navegação principal">
        <a href="#solucoes">Soluções</a>
        <a href="#split">Split de Pagamentos</a>
        <a href="#planos">Planos</a>
        <a href="#sobre">Sobre nós</a>
      </nav>
      <a href="#contato" class="btn btn--primary header__cta">Fale conosco</a>
    </div>
  </header>

  <!-- ===== Hero ===== -->
  <section class="hero">
    <div class="container hero__inner">
      <div class="hero__copy">
        <span class="hero__badge">Contabilidade + tecnologia + gente</span>
        <h1>
          Pare de perder <em>dinheiro</em>.
        </h1>
        <p class="hero__sub">
          Conheça as soluções inteligentes da VIA e aumente a sua
          rentabilidade em até <strong>50%</strong> — gestão financeira,
          contábil e de recebíveis em um único lugar.
        </p>
        <div class="hero__actions">
          <a href={`mailto:${EMAIL}?subject=Quero%20agendar%20uma%20demo`} class="btn btn--primary">Agende uma demo</a>
          <a href={WHATSAPP} target="_blank" rel="noopener" class="btn btn--ghost btn--ghost-dark">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2a10 10 0 0 0-8.6 15.1L2 22l5.1-1.3A10 10 0 1 0 12 2zm5.4 14.1c-.2.6-1.3 1.2-1.8 1.3-.5 0-1 .2-3.4-.7-2.9-1.1-4.7-4-4.9-4.2-.1-.2-1.1-1.5-1.1-2.9s.7-2 1-2.3c.2-.3.5-.3.7-.3h.5c.2 0 .4 0 .6.4l.9 2.1c.1.2.1.4 0 .6l-.4.6-.5.5c-.2.2-.3.3-.1.6.2.3.9 1.5 2 2.4 1.4 1.2 2.5 1.6 2.9 1.8.3.2.5.1.7-.1l1-1.2c.2-.3.4-.2.7-.1l2.1 1c.3.2.5.3.6.4 0 .1 0 .7-.2 1.2z"/></svg>
            WhatsApp
          </a>
        </div>
        <ul class="hero__stats" role="list">
          <li><strong>+50%</strong><span>de rentabilidade potencial</span></li>
          <li><strong>1 lugar</strong><span>PDV, financeiro e contábil</span></li>
          <li><strong>Desde 2012</strong><span>simplificando back-office</span></li>
        </ul>
      </div>

      <div class="hero__visual" aria-hidden="true">
        <div class="hero__card hero__card--main">
          <span class="hero__card-label">Divisão automática</span>
          <div class="hero__bars">
            <div class="hero__bar" style="--w: 92%"><i></i><b>Franqueadora</b></div>
            <div class="hero__bar" style="--w: 64%"><i></i><b>Unidade</b></div>
            <div class="hero__bar" style="--w: 40%"><i></i><b>Parceiros</b></div>
          </div>
          <p class="hero__card-foot">Pagos na hora, sem planilhas ✓</p>
        </div>
        <div class="hero__card hero__card--chip">
          <strong>NF-e emitida</strong>
          <span>setup feito uma única vez</span>
        </div>
        <div class="hero__card hero__card--chip hero__card--chip2">
          <strong>Conciliação ok</strong>
          <span>relatório pronto para você</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== Soluções ===== -->
  <section class="section solucoes" id="solucoes">
    <div class="container">
      <span class="eyebrow">Soluções</span>
      <h2 class="section-title">Uma empresa de contabilidade com múltiplas funções</h2>
      <div class="solucoes__grid">
        <article class="solucao-card">
          <div class="solucao-card__icon" aria-hidden="true">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a7 7 0 0 1 7 7c0 2.4-1.2 4-2.5 5.5-.8 1-1.5 2-1.5 3.5h-6c0-1.5-.7-2.5-1.5-3.5C6.2 13 5 11.4 5 9a7 7 0 0 1 7-7z"/><path d="M9 21h6"/><path d="M10 18h4"/></svg>
          </div>
          <h3>Contabilidade Inteligente</h3>
          <p class="solucao-card__tag">É mais que digital, é inteligente!</p>
          <p>
            Combine tecnologia de ponta e atendimento humano especializado para
            ter uma contabilidade completa, acessível e eficiente. Com todos os
            recursos de uma plataforma digital e uma equipe altamente
            qualificada, você conta com o suporte que precisa, sempre à
            disposição para te atender.
          </p>
        </article>
        <article class="solucao-card">
          <div class="solucao-card__icon" aria-hidden="true">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="M3 10h18"/><path d="M7 15h4"/></svg>
          </div>
          <h3>BPO Financeiro</h3>
          <p class="solucao-card__tag">Economize com nossa solução completa!</p>
          <p>
            Elimine os custos com sistemas e equipe interna. Oferecemos uma
            plataforma financeira integrada, totalmente gerenciada para você.
            Assumimos contas a pagar e a receber, realizamos conciliações e
            efetuamos pagamentos diretamente no banco. Sua única tarefa é
            acompanhar os relatórios e autorizar as transações — mais tempo
            para focar no que realmente importa: o crescimento do seu negócio.
          </p>
        </article>
      </div>
    </div>
  </section>

  <!-- ===== Split de Pagamentos ===== -->
  <section class="section split" id="split">
    <div class="container">
      <span class="eyebrow eyebrow--dark">Split de Pagamentos</span>
      <h2 class="section-title split__title">Split de pagamentos | divisão de recebíveis</h2>
      <p class="section-lead split__lead">
        Evite bitributação, erros e atrasos nos pagamentos com o Split de Pagamentos!
      </p>

      <div class="split__compare">
        <div class="split__col split__col--sem">
          <h4><span aria-hidden="true">✕</span> Sem a VIA</h4>
          <ol>
            {semVia.map((passo) => <li>{passo}</li>)}
          </ol>
        </div>
        <div class="split__col split__col--com">
          <h4><span aria-hidden="true">✓</span> Com a VIA</h4>
          <ol>
            {comVia.map((passo) => <li>{passo}</li>)}
          </ol>
        </div>
      </div>

      <div class="split__txt">
        <p>
          Otimize a gestão dos recebíveis com automação e regras totalmente
          personalizáveis, adaptadas às necessidades específicas do seu
          negócio. Com uma estrutura robusta de subcontas, o processo de
          transferência de recursos se torna ainda mais simples e eficiente.
        </p>
        <p>
          Além dessas vantagens, a eliminação da bitributação permite
          direcionar mais recursos para investimentos estratégicos e
          impulsionar o crescimento da sua empresa.
        </p>
      </div>
      <div class="split__cta">
        <a href={`mailto:${EMAIL}?subject=Quero%20agendar%20uma%20demo`} class="btn btn--light">Agende uma demo</a>
      </div>
    </div>
  </section>

  <!-- ===== Benefícios ===== -->
  <section class="section beneficios" id="beneficios">
    <div class="container">
      <span class="eyebrow">Mais benefícios</span>
      <h2 class="section-title">Tudo o que vem junto com a VIA</h2>
      <div class="beneficios__grid">
        <article class="beneficio-card">
          <div class="beneficio-card__icon" aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2h9l5 5v15H6z"/><path d="M15 2v5h5"/><path d="M9 13h6"/><path d="M9 17h6"/></svg>
          </div>
          <h3>Notas fiscais</h3>
          <p>Emita notas fiscais de forma descomplicada e preencha o setup inicial apenas uma vez.</p>
        </article>
        <article class="beneficio-card">
          <div class="beneficio-card__icon" aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.5.5l3-3a5 5 0 0 0-7-7l-1.7 1.7"/><path d="M14 11a5 5 0 0 0-7.5-.5l-3 3a5 5 0 0 0 7 7l1.7-1.7"/></svg>
          </div>
          <h3>Link de pagamento</h3>
          <p>Receba com DOC, Boleto, PIX, Bolepix e outros sem precisar de maquininha.</p>
        </article>
        <article class="beneficio-card">
          <div class="beneficio-card__icon" aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M22 7 13.5 15.5 8.5 10.5 2 17"/><path d="M16 7h6v6"/></svg>
          </div>
          <h3>Redução dos tributos</h3>
          <p>Reduza a carga tributária e garanta pagamentos rápidos e diretos.</p>
        </article>
      </div>
    </div>
  </section>

  <!-- ===== Planos ===== -->
  <section class="section planos" id="planos">
    <div class="container">
      <span class="eyebrow">Planos</span>
      <h2 class="section-title">Encontre o melhor plano para o seu negócio</h2>
      <div class="planos__grid">
        {planos.map((plano) => (
          <article class={`plano-card ${plano.destaque ? 'plano-card--destaque' : ''}`}>
            {plano.destaque && <span class="plano-card__flag">Mais completo p/ PMEs</span>}
            <h3>{plano.nome}</h3>
            <p class="plano-card__sub">{plano.subtitulo}</p>
            <ul role="list">
              {plano.itens.map((item) => (
                <li>
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                  {item}
                </li>
              ))}
            </ul>
            <a href={WHATSAPP} target="_blank" rel="noopener" class={`btn ${plano.destaque ? 'btn--primary' : 'btn--ghost'}`}>Eu quero</a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== Sobre nós ===== -->
  <section class="section sobre" id="sobre">
    <div class="container">
      <span class="eyebrow">Sobre nós</span>
      <h2 class="section-title">Uma história que começou resolvendo o próprio problema</h2>
      <p class="section-lead">
        Em 2007, a <a href="https://www.drywash.com.br/" target="_blank" rel="noopener" class="sobre__link">DryWash</a>
        enfrentou desafios administrativos que foram resolvidos com a criação de um
        Centro de Serviços Compartilhados — e essa experiência virou a VIA.
      </p>
      <ol class="sobre__timeline" role="list">
        {timeline.map((etapa) => (
          <li>
            <span class="sobre__ano">{etapa.ano}</span>
            <p>{etapa.texto}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- ===== Contato / CTA final ===== -->
  <section class="section contato" id="contato">
    <div class="container contato__inner">
      <div>
        <h2 class="contato__title">Vem com a gente</h2>
        <p class="contato__lead">
          Agende uma demo e descubra quanto o seu negócio pode ganhar com a VIA.
        </p>
      </div>
      <div class="contato__cards">
        <a href={`mailto:${EMAIL}`} class="contato__card">
          <span class="contato__card-label">E-mail</span>
          <strong>{EMAIL}</strong>
        </a>
        <a href={WHATSAPP} target="_blank" rel="noopener" class="contato__card">
          <span class="contato__card-label">WhatsApp</span>
          <strong>(11) 99107-9503</strong>
        </a>
        <div class="contato__card contato__card--static">
          <span class="contato__card-label">Endereço</span>
          <strong>Av. das Cerejeiras, 232 — Loja 02<br />Vila Maria, São Paulo/SP · CEP 02124-001</strong>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== Footer ===== -->
  <footer class="footer">
    <div class="container footer__inner">
      <div class="footer__brand">
        <img src="/logo-via-white.svg" alt="VIA" width="76" height="26" />
        <p>Soluções automatizadas de back-office para micro e pequenas empresas.</p>
      </div>
      <nav class="footer__nav" aria-label="Links do rodapé">
        <a href="#solucoes">Soluções</a>
        <a href="#split">Split de Pagamentos</a>
        <a href="#planos">Planos</a>
        <a href="#sobre">Sobre nós</a>
        <a href="#contato">Contato</a>
      </nav>
      <div class="footer__social">
        <span>Fique conectado</span>
        <ul role="list">
          <li><a href="https://www.instagram.com/viacomvc" target="_blank" rel="noopener" aria-label="Instagram"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="0.5" fill="currentColor"/></svg></a></li>
          <li><a href="https://www.facebook.com/share/q3kBGJ1xVQ8JtPxn/" target="_blank" rel="noopener" aria-label="Facebook"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg></a></li>
          <li><a href="https://www.linkedin.com/company/viacomvc/" target="_blank" rel="noopener" aria-label="LinkedIn"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-4 0v7h-4V9h4v1.5A6 6 0 0 1 16 8z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg></a></li>
          <li><a href={WHATSAPP} target="_blank" rel="noopener" aria-label="WhatsApp"><svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2a10 10 0 0 0-8.6 15.1L2 22l5.1-1.3A10 10 0 1 0 12 2zm5.4 14.1c-.2.6-1.3 1.2-1.8 1.3-.5 0-1 .2-3.4-.7-2.9-1.1-4.7-4-4.9-4.2-.1-.2-1.1-1.5-1.1-2.9s.7-2 1-2.3c.2-.3.5-.3.7-.3h.5c.2 0 .4 0 .6.4l.9 2.1c.1.2.1.4 0 .6l-.4.6-.5.5c-.2.2-.3.3-.1.6.2.3.9 1.5 2 2.4 1.4 1.2 2.5 1.6 2.9 1.8.3.2.5.1.7-.1l1-1.2c.2-.3.4-.2.7-.1l2.1 1c.3.2.5.3.6.4 0 .1 0 .7-.2 1.2z"/></svg></a></li>
        </ul>
      </div>
    </div>
    <div class="footer__copy">
      <div class="container">
        <p>© 2026 Via CSC Processamento de Dados Ltda | Todos os direitos reservados.</p>
      </div>
    </div>
  </footer>
</Base>

<style>
  /* ===== Header ===== */
  .header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(250, 253, 254, 0.85);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--line);
  }

  .header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding-block: 1rem;
  }

  .header__logo img { height: 30px; width: auto; }

  .header__nav {
    display: flex;
    gap: 2rem;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.95rem;
  }

  .header__nav a { color: var(--ink-2); transition: color 0.15s ease; }
  .header__nav a:hover { color: var(--via); }

  .header__cta { padding: 0.65rem 1.4rem; }

  @media (max-width: 820px) {
    .header__nav { display: none; }
  }

  /* ===== Hero ===== */
  .hero {
    position: relative;
    overflow: hidden;
    background:
      radial-gradient(900px 480px at 85% -10%, rgba(0, 164, 198, 0.35), transparent 65%),
      radial-gradient(700px 420px at -10% 110%, rgba(23, 195, 232, 0.22), transparent 60%),
      linear-gradient(160deg, var(--ink) 0%, var(--ink-2) 100%);
    color: var(--white);
  }

  .hero__inner {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    align-items: center;
    gap: clamp(2rem, 5vw, 4rem);
    padding-block: clamp(4.5rem, 10vw, 8rem);
  }

  .hero__badge {
    display: inline-block;
    font-family: var(--font-display);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--via-soft);
    border: 1px solid rgba(126, 220, 239, 0.35);
    border-radius: var(--radius-pill);
    padding: 0.45rem 1rem;
    margin-bottom: 1.5rem;
  }

  .hero h1 {
    font-size: clamp(2.4rem, 5.5vw, 4rem);
    font-weight: 800;
  }

  .hero h1 em {
    font-style: normal;
    color: transparent;
    background: linear-gradient(100deg, var(--via-bright), var(--via-soft));
    -webkit-background-clip: text;
    background-clip: text;
  }

  .hero__sub {
    margin-top: 1.4rem;
    font-size: 1.15rem;
    color: rgba(255, 255, 255, 0.82);
    max-width: 48ch;
  }

  .hero__sub strong { color: var(--via-soft); }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
    margin-top: 2.2rem;
  }

  .btn--ghost-dark {
    color: var(--white);
    border-color: rgba(255, 255, 255, 0.3);
  }

  .btn--ghost-dark:hover { border-color: var(--via-soft); color: var(--via-soft); }

  .hero__stats {
    display: flex;
    flex-wrap: wrap;
    gap: clamp(1.5rem, 4vw, 3rem);
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.14);
  }

  .hero__stats li { display: grid; gap: 0.15rem; }

  .hero__stats strong {
    font-family: var(--font-display);
    font-size: 1.35rem;
    color: var(--via-soft);
  }

  .hero__stats span { font-size: 0.85rem; color: rgba(255, 255, 255, 0.65); }

  /* Cartões ilustrativos do hero */
  .hero__visual { position: relative; min-height: 360px; }

  .hero__card {
    position: absolute;
    background: rgba(255, 255, 255, 0.97);
    color: var(--ink);
    border-radius: var(--radius-md);
    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.35);
    padding: 1.4rem;
  }

  .hero__card--main {
    inset: 12% 8% auto 0;
    width: min(340px, 88%);
  }

  .hero__card-label {
    font-family: var(--font-display);
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--via-dark);
  }

  .hero__bars { display: grid; gap: 0.8rem; margin-top: 1rem; }

  .hero__bar {
    display: grid;
    gap: 0.3rem;
    font-size: 0.8rem;
